{
  "name": "bengali-subtitle-app",
  "version": "1.0.0",
  "description": "Watch any video with live Bengali subtitles",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.yourname.bengali-subtitles",
    "productName": "Bengali Subtitles",
    "directories": { "output": "dist" },
    "extraResources": [
      { "from": "backend/", "to": "backend/", "filter": ["**/*"] }
    ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}